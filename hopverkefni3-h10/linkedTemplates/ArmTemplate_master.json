{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "hopverkefni3-h10"
		},
		"src_db_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'src_db'"
		},
		"vh_db_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'vh_db'"
		},
		"src_db_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "vgbi2026-trans.duckdns.org"
		},
		"src_db_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "registerdb"
		},
		"src_db_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "h10user"
		},
		"vh_db_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "vgbi2026-vh.duckdns.org"
		},
		"vh_db_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "vh_h10"
		},
		"vh_db_properties_typeProperties_username": {
			"type": "string",
			"defaultValue": "h10user"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "hopverkefni3-h10_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"src_db_password": {
						"value": "[parameters('src_db_password')]"
					},
					"vh_db_password": {
						"value": "[parameters('vh_db_password')]"
					},
					"src_db_properties_typeProperties_server": {
						"value": "[parameters('src_db_properties_typeProperties_server')]"
					},
					"src_db_properties_typeProperties_database": {
						"value": "[parameters('src_db_properties_typeProperties_database')]"
					},
					"src_db_properties_typeProperties_username": {
						"value": "[parameters('src_db_properties_typeProperties_username')]"
					},
					"vh_db_properties_typeProperties_server": {
						"value": "[parameters('vh_db_properties_typeProperties_server')]"
					},
					"vh_db_properties_typeProperties_database": {
						"value": "[parameters('vh_db_properties_typeProperties_database')]"
					},
					"vh_db_properties_typeProperties_username": {
						"value": "[parameters('vh_db_properties_typeProperties_username')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}